{
  "name": "bowen-lift-ferry",
  "version": "0.0.1",
  "description": " ",
  "productName": "Bowen Lift",
  "author": "Tom Carchrae <tom@intellecti.ca>",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "deploy:webapp": "git push origin main",
    "deploy:webapp:production": "git push origin main:production",
    "deploy:rules": "npx firebase deploy --project bowen-ferry-staging --only firestore:rules",
    "deploy:functions": "npx firebase deploy --project bowen-ferry-staging --only functions",
    "deploy:rules:production": "npx firebase deploy --project bowen-ferry --only firestore:rules",
    "deploy:functions:production": "npx firebase deploy --project bowen-ferry --only functions",
    "dev": "quasar dev -m spa",
    "build": "quasar build -m pwa",
    "postinstall": "quasar prepare",
    "firebase-config": "bash scripts/get-firebase-config.sh",
    "update-vapid-keys:staging": "bash scripts/rotate-vapid-keys.sh staging",
    "generate-vapid-keys:staging": "bash scripts/generate-vapid-keys.sh staging",
    "set-firebase-secrets:staging": "bash scripts/set-firebase-secrets.sh staging",
    "set-vapid-public-key:staging": "bash scripts/set-vapid-public-key.sh"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "core-js": "^3.31.1",
    "dotenv": "^17.4.2",
    "firebase": "^12.12.1",
    "quasar": "^2.16.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.5.22",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-webpack": "^4.1.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-webpack-plugin": "^4.2.0",
    "firebase-tools": "^14.3.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-style-loader": "^4.1.3",
    "workbox-webpack-plugin": "^7.4.0"
  },
  "browserslist": [
    "last 10 Chrome versions",
    "last 10 Firefox versions",
    "last 4 Edge versions",
    "last 7 Safari versions",
    "last 8 Android versions",
    "last 8 ChromeAndroid versions",
    "last 8 FirefoxAndroid versions",
    "last 10 iOS versions",
    "last 5 Opera versions"
  ],
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
