rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /ferryStatus/current {
      allow read: if true;
      allow write: if false;
    }
    match /ferryStatus/{docId} {
      allow read: if false;
      allow write: if false;
    }
    match /subscriptions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /notificationSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Rides collection
    match /rides/{rideId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid;
            allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.authorUid;
    }

    // Capacity history collection (server and authenticated users). Users may
    // delete their own reports (automated records have no userUid, so they
    // can never match the delete rule); no updates — a re-tag is a new doc.
    match /capacityHistory/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['sailingKey', 'capacity', 'userUid'])
        && request.resource.data.userUid == request.auth.uid;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userUid;
    }

    // Lineup reports: riders marking when the car lineup reached the
    // crosswalk. Same shape as capacityHistory: create + own-delete only.
    match /lineupReports/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['sailingKey', 'crosswalkAt', 'userUid'])
        && request.resource.data.userUid == request.auth.uid;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userUid;
    }

    // Sailing status collection (server-write only)
    match /sailingStatus/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Snapshots collection (server-write only)
    match /snapshots/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Precomputed leaderboard aggregate (server-write only)
    match /aggregates/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}